@page "/results"
@attribute [Authorize]
@attribute [StreamRendering]
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject SleepAnalysisService AnalysisService
@inject IJSRuntime JsRuntime

<PageTitle>Risultati e Classifica</PageTitle>

<h1>Risultati e Classifica</h1>

<div class="alert alert-light border mb-3">
    <strong>💡 Calcolo ponderato per orario:</strong>
    🌙 Sera = 1.5× &nbsp;|&nbsp; ☀️ Pomeriggio = 1.0× &nbsp;|&nbsp; 🌅 Mattino = 0.6×
    — i fattori serali pesano di più perché sono più vicini al sonno.
</div>

@if (_isLoading)
{
    <p class="text-muted"><em>Caricamento analisi...</em></p>
}
else
{
    <p><strong>Giorni tracciati:</strong> @_report.TotalDays</p>

    <h4 class="mt-4">📊 Classifica fattori singoli (rischio ponderato)</h4>
    @if (_report.SingleFactorRanking.Count == 0)
    {
        <p class="text-muted">Nessun dato disponibile per i fattori singoli.</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-sm table-striped align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Fattore</th>
                        <th>Occorrenze</th>
                        <th>😴 Male</th>
                        <th>😐 Così così</th>
                        <th>😊 Bene</th>
                        <th>Rischio ponderato</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in _report.SingleFactorRanking.Take(20))
                    {
                        <tr>
                            <td><strong>@item.Key</strong></td>
                            <td>@item.Occurrences</td>
                            <td class="text-danger">@item.BadCount</td>
                            <td class="text-warning">@item.SoSoCount</td>
                            <td class="text-success">@item.GoodCount</td>
                            <td>
                                <span class="badge @(item.RiskScore > 0.3 ? "bg-danger" : item.RiskScore > 0 ? "bg-warning text-dark" : "bg-success")">
                                    @item.RiskScore.ToString("F2")
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <h4 class="mt-4">🔗 Classifica combinazioni (coppie di fattori)</h4>
    @if (_report.CombinedFactorRanking.Count == 0)
    {
        <p class="text-muted">Nessuna combinazione trovata ancora (servono almeno 2 giorni ripetuti).</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-sm table-striped align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Combinazione</th>
                        <th>Occorrenze</th>
                        <th>😴 Male</th>
                        <th>😐 Così così</th>
                        <th>😊 Bene</th>
                        <th>Rischio ponderato</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in _report.CombinedFactorRanking.Take(20))
                    {
                        <tr>
                            <td><strong>@item.Key</strong></td>
                            <td>@item.Occurrences</td>
                            <td class="text-danger">@item.BadCount</td>
                            <td class="text-warning">@item.SoSoCount</td>
                            <td class="text-success">@item.GoodCount</td>
                            <td>
                                <span class="badge @(item.RiskScore > 0.3 ? "bg-danger" : item.RiskScore > 0 ? "bg-warning text-dark" : "bg-success")">
                                    @item.RiskScore.ToString("F2")
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <h4 class="mt-4">🛡️ Fattori protettivi (più notti buone che cattive)</h4>
    @if (_report.ExcludedFactors.Count == 0)
    {
        <p class="text-muted">Nessun fattore protettivo rilevato ancora.</p>
    }
    else
    {
        <ul class="list-group">
            @foreach (var item in _report.ExcludedFactors.Take(20))
            {
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    <span>@item.Key</span>
                    <span>
                        😊 <strong>@item.GoodCount</strong> &nbsp;|&nbsp;
                        😴 @item.BadCount &nbsp;|&nbsp;
                        totale: @item.Occurrences
                    </span>
                </li>
            }
        </ul>
    }
}

@code {
    private AnalysisReport _report = new([], [], [], 0);
    private bool _isLoading = true;
    private DotNetObjectReference<Results>? _dotNetRef;
    private readonly string _signalRKey = $"results-{Guid.NewGuid():N}";

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        _dotNetRef = DotNetObjectReference.Create(this);
        await JsRuntime.InvokeVoidAsync("sleepFactorsRealtime.start", _signalRKey, _dotNetRef);
    }

    [JSInvokable]
    public async Task HandleRealtimeRefresh()
    {
        await LoadAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _report = await AnalysisService.BuildReportAsync();
        _isLoading = false;
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JsRuntime.InvokeVoidAsync("sleepFactorsRealtime.stop", _signalRKey);
        }
        catch
        {
        }

        _dotNetRef?.Dispose();
    }
}
