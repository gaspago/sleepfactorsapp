@page "/track"
@attribute [Authorize]
@rendermode InteractiveServer
@inject DailyLogService DailyLogService

<PageTitle>Aggiungi Fattori Giornalieri</PageTitle>

<h1>Aggiungi Fattori Giornalieri</h1>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <label class="form-label fw-bold">Giorno dei fattori (pre-salvataggio)</label>
        <InputDate class="form-control" @bind-Value="SelectedDay" />
    </div>
    <div class="col-md-8">
        <label class="form-label fw-bold">Note fattori</label>
        <InputText class="form-control" @bind-Value="DailyNotes" placeholder="Note opzionali sui fattori della giornata..." />
    </div>
</div>

<div class="card mb-3">
    <div class="card-header fw-bold">Aggiungi fattore</div>
    <div class="card-body">

        <div class="mb-3">
            <label class="form-label fw-bold">Tipo di fattore</label>
            <div class="btn-group w-100" role="group">
                <button type="button" class="btn @(IsMealMode ? "btn-success" : "btn-outline-success")" @onclick="() => IsMealMode = true">
                    🍽️ Pasto
                </button>
                <button type="button" class="btn @(!IsMealMode ? "btn-primary" : "btn-outline-primary")" @onclick="() => IsMealMode = false">
                    ⚡ Fattore singolo
                </button>
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">Momento della giornata</label>
            <div class="btn-group w-100" role="group">
                <button type="button" class="btn @(NewTimeSlot == TimeSlot.Mattino ? "btn-info" : "btn-outline-info")" @onclick="() => NewTimeSlot = TimeSlot.Mattino">
                    🌅 Mattino
                </button>
                <button type="button" class="btn @(NewTimeSlot == TimeSlot.Pomeriggio ? "btn-warning" : "btn-outline-warning")" @onclick="() => NewTimeSlot = TimeSlot.Pomeriggio">
                    ☀️ Pomeriggio
                </button>
                <button type="button" class="btn @(NewTimeSlot == TimeSlot.Sera ? "btn-dark" : "btn-outline-dark")" @onclick="() => NewTimeSlot = TimeSlot.Sera">
                    🌙 Sera
                </button>
            </div>
            <small class="text-muted">La sera ha peso maggiore nell'analisi (più vicina al sonno)</small>
        </div>

        @if (IsMealMode)
        {
            <div class="mb-3">
                <label class="form-label fw-bold">Tipo di pasto</label>
                <input class="form-control" list="meal-types-list" value="@NewMealType" @onchange="@((ChangeEventArgs e) => NewMealType = e.Value?.ToString() ?? string.Empty)" placeholder="Es. pranzo, cena, merenda..." />
                <datalist id="meal-types-list">
                    @foreach (var meal in HistoricalMealTypes)
                    {
                        <option value="@meal" />
                    }
                </datalist>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Ingredienti</label>
                @if (CurrentIngredients.Count > 0)
                {
                    <ul class="list-group list-group-flush mb-2">
                        @foreach (var ing in CurrentIngredients.ToList())
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center py-1 px-2">
                                <span>@ing</span>
                                <button class="btn btn-sm btn-outline-danger" type="button" @onclick="() => CurrentIngredients.Remove(ing)">✕</button>
                            </li>
                        }
                    </ul>
                }
                <div class="input-group">
                    <input class="form-control" list="ingredients-list" value="@NewIngredient" @oninput="@((ChangeEventArgs e) => NewIngredient = e.Value?.ToString())"
                           @onkeydown="IngredientKeyDown" placeholder="Scrivi ingrediente e premi Aggiungi..." />
                    <datalist id="ingredients-list">
                        @foreach (var ingredient in HistoricalIngredients)
                        {
                            <option value="@ingredient" />
                        }
                    </datalist>
                    <button class="btn btn-outline-secondary" type="button" @onclick="AddIngredient">+ Aggiungi</button>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">Note pasto (opzionale)</label>
                <InputText class="form-control" @bind-Value="NewMealDetail" placeholder="Dettaglio opzionale..." />
            </div>
        }
        else
        {
            <div class="mb-3">
                <label class="form-label fw-bold">Categoria</label>
                <InputSelect class="form-select" @bind-Value="NewSimpleCategory">
                    <option value="@FactorCategory.Nap">😴 Sonnellino</option>
                    <option value="@FactorCategory.Conflict">😤 Litigio / Conflitto</option>
                    <option value="@FactorCategory.Bath">🛁 Bagnetto / Doccia</option>
                    <option value="@FactorCategory.Incident">⚠️ Incidente / Caduta</option>
                    <option value="@FactorCategory.Other">📌 Altro</option>
                </InputSelect>
            </div>

            <div class="row g-2">
                <div class="col-md-6">
                    <label class="form-label fw-bold">Nome fattore</label>
                    <input class="form-control" list="factor-names-list" value="@NewSimpleName" @onchange="@((ChangeEventArgs e) => NewSimpleName = e.Value?.ToString())" placeholder="Es. sonnellino 2 ore, litigio genitori..." />
                    <datalist id="factor-names-list">
                        @foreach (var name in HistoricalSimpleFactorNames)
                        {
                            <option value="@name" />
                        }
                    </datalist>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Dettaglio (opzionale)</label>
                    <InputText class="form-control" @bind-Value="NewSimpleDetail" placeholder="Dettaglio opzionale..." />
                </div>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(InputError))
        {
            <div class="alert alert-warning mt-2 mb-0">@InputError</div>
        }

        <button class="btn btn-primary mt-3 w-100" type="button" @onclick="AddFactor">
            + Aggiungi alla lista
        </button>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <strong>Fattori inseriti</strong>
        <span class="badge bg-secondary">@(SimpleFactors.Count + MealFactors.Count)</span>
    </div>
    <div class="card-body">
        @if (SimpleFactors.Count == 0 && MealFactors.Count == 0)
        {
            <p class="text-muted mb-0">Nessun fattore aggiunto ancora.</p>
        }
        else
        {
            <ul class="list-group list-group-flush">
                @for (var i = 0; i < SimpleFactors.Count; i++)
                {
                    var factor = SimpleFactors[i];
                    var idx = i;
                    <li class="list-group-item d-flex justify-content-between align-items-start">
                        <div>
                            <span class="badge @TimeSlotBadgeClass(factor.TimeSlot) me-1">@TimeSlotIcon(factor.TimeSlot) @TimeSlotLabel(factor.TimeSlot)</span>
                            <span class="badge bg-secondary me-1">@CategoryLabel(factor.Category)</span>
                            <strong>@factor.Name</strong>
                            @if (!string.IsNullOrWhiteSpace(factor.Detail))
                            {
                                <span class="text-muted ms-1">— @factor.Detail</span>
                            }
                        </div>
                        <button class="btn btn-sm btn-outline-danger" type="button" @onclick="() => SimpleFactors.RemoveAt(idx)">✕</button>
                    </li>
                }
                @for (var i = 0; i < MealFactors.Count; i++)
                {
                    var meal = MealFactors[i];
                    var idx = i;
                    <li class="list-group-item">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <span class="badge @TimeSlotBadgeClass(meal.TimeSlot) me-1">@TimeSlotIcon(meal.TimeSlot) @TimeSlotLabel(meal.TimeSlot)</span>
                                <span class="badge bg-success me-1">Pasto</span>
                                <strong>@meal.MealType</strong>
                                @if (!string.IsNullOrWhiteSpace(meal.Detail))
                                {
                                    <span class="text-muted ms-1">— @meal.Detail</span>
                                }
                            </div>
                            <button class="btn btn-sm btn-outline-danger" type="button" @onclick="() => MealFactors.RemoveAt(idx)">✕</button>
                        </div>
                        @if (meal.Ingredients.Count > 0)
                        {
                            <ul class="mb-0 mt-1 ps-3">
                                @foreach (var ing in meal.Ingredients)
                                {
                                    <li>@ing</li>
                                }
                            </ul>
                        }
                    </li>
                }
            </ul>
        }
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(StatusMessage))
{
    <div class="alert alert-success mt-2">@StatusMessage</div>
}

<div class="row g-2 mb-3">
    <div class="col-md-6 d-grid">
        <button class="btn btn-primary btn-lg" type="button" @onclick="SaveDraft">
            💾 Pre-salva fattori (senza sonno)
        </button>
    </div>
    <div class="col-md-6 d-grid">
        <button class="btn btn-success btn-lg" type="button" @onclick="CommitSleep" disabled="@string.IsNullOrWhiteSpace(CommitDayIso)">
            ✅ Commit finale sonno
        </button>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header fw-bold">Commit finale del sonno (giorno successivo)</div>
    <div class="card-body">
        @if (PendingDraftDays.Count == 0)
        {
            <p class="text-muted mb-0">Nessuna giornata in pre-salvataggio.</p>
        }
        else
        {
            <div class="row g-2">
                <div class="col-md-4">
                    <label class="form-label">Giorno da confermare</label>
                    <select class="form-select" value="@CommitDayIso" @onchange="@((ChangeEventArgs e) => CommitDayIso = e.Value?.ToString())">
                        <option value="">Seleziona giorno...</option>
                        @foreach (var day in PendingDraftDays)
                        {
                            <option value="@day.ToString("yyyy-MM-dd")">@day.ToString("dd/MM/yyyy")</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Come ha dormito</label>
                    <InputSelect class="form-select" @bind-Value="SelectedSleepQuality">
                        <option value="@SleepQuality.Bad">😴 Ha dormito male</option>
                        <option value="@SleepQuality.SoSo">😐 Ha dormito così così</option>
                        <option value="@SleepQuality.Good">😊 Ha dormito bene</option>
                    </InputSelect>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Note commit (opzionale)</label>
                    <InputText class="form-control" @bind-Value="CommitNotes" placeholder="Nota finale sul sonno..." />
                </div>
            </div>
        }
    </div>
</div>

@code {
    private DateOnly SelectedDay { get; set; } = DateOnly.FromDateTime(DateTime.Today);
    private SleepQuality SelectedSleepQuality { get; set; } = SleepQuality.SoSo;
    private string? DailyNotes { get; set; }

    private bool IsMealMode { get; set; }
    private TimeSlot NewTimeSlot { get; set; } = TimeSlot.Pomeriggio;

    private IReadOnlyList<string> HistoricalMealTypes { get; set; } = [];
    private IReadOnlyList<string> HistoricalIngredients { get; set; } = [];
    private IReadOnlyList<string> HistoricalSimpleFactorNames { get; set; } = [];
    private IReadOnlyList<DateOnly> PendingDraftDays { get; set; } = [];
    private string? CommitDayIso { get; set; }
    private string? CommitNotes { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await RefreshReferenceDataAsync();
    }

    private async Task RefreshReferenceDataAsync()
    {
        HistoricalMealTypes = await DailyLogService.GetHistoricalMealTypesAsync();
        HistoricalIngredients = await DailyLogService.GetHistoricalIngredientsAsync();
        HistoricalSimpleFactorNames = await DailyLogService.GetHistoricalSimpleFactorNamesAsync();
        PendingDraftDays = await DailyLogService.GetPendingDraftDaysAsync();
    }

    // Fattore singolo
    private FactorCategory NewSimpleCategory { get; set; } = FactorCategory.Other;
    private string? NewSimpleName { get; set; }
    private string? NewSimpleDetail { get; set; }

    // Pasto
    private string NewMealType { get; set; } = "pranzo";
    private string? NewMealDetail { get; set; }
    private List<string> CurrentIngredients { get; } = [];
    private string? NewIngredient { get; set; }

    private string? StatusMessage { get; set; }
    private string? InputError { get; set; }

    private List<SimpleFactorInput> SimpleFactors { get; } = [];
    private List<MealFactorInput> MealFactors { get; } = [];

    private static string CategoryLabel(FactorCategory c) => c switch
    {
        FactorCategory.Nap => "Sonnellino",
        FactorCategory.Conflict => "Litigio",
        FactorCategory.Bath => "Bagnetto",
        FactorCategory.Incident => "Incidente",
        _ => "Altro"
    };

    private static string TimeSlotLabel(TimeSlot t) => t switch
    {
        TimeSlot.Mattino => "Mattino",
        TimeSlot.Pomeriggio => "Pomeriggio",
        _ => "Sera"
    };

    private static string TimeSlotIcon(TimeSlot t) => t switch
    {
        TimeSlot.Mattino => "🌅",
        TimeSlot.Pomeriggio => "☀️",
        _ => "🌙"
    };

    private static string TimeSlotBadgeClass(TimeSlot t) => t switch
    {
        TimeSlot.Mattino => "bg-info text-dark",
        TimeSlot.Pomeriggio => "bg-warning text-dark",
        _ => "bg-dark"
    };

    private void AddIngredient()
    {
        var trimmed = (NewIngredient ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(trimmed)) return;
        if (!CurrentIngredients.Contains(trimmed, StringComparer.OrdinalIgnoreCase))
            CurrentIngredients.Add(trimmed);
        NewIngredient = null;
        InputError = null;
    }

    private void IngredientKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") AddIngredient();
    }

    private void AddFactor()
    {
        InputError = null;
        StatusMessage = null;

        if (IsMealMode)
        {
            if (CurrentIngredients.Count == 0)
            {
                InputError = "Aggiungi almeno un ingrediente al pasto.";
                return;
            }
            MealFactors.Add(new MealFactorInput(NewMealType, CurrentIngredients.ToList(), NewMealDetail, NewTimeSlot));
            CurrentIngredients.Clear();
            NewMealDetail = null;
            StatusMessage = "Pasto aggiunto alla lista.";
        }
        else
        {
            if (string.IsNullOrWhiteSpace(NewSimpleName))
            {
                InputError = "Il nome del fattore è obbligatorio.";
                return;
            }
            SimpleFactors.Add(new SimpleFactorInput(NewSimpleCategory, NewSimpleName.Trim(), NewSimpleDetail, NewTimeSlot));
            NewSimpleName = null;
            NewSimpleDetail = null;
            StatusMessage = "Fattore aggiunto alla lista.";
        }
    }

    private async Task SaveDraft()
    {
        StatusMessage = null;
        if (SimpleFactors.Count == 0 && MealFactors.Count == 0)
        {
            StatusMessage = "Aggiungi almeno un fattore prima del pre-salvataggio.";
            return;
        }

        await DailyLogService.SaveDraftAsync(new DailyDraftInput(
            SelectedDay,
            DailyNotes,
            SimpleFactors.ToList(),
            MealFactors.ToList()));

        SimpleFactors.Clear();
        MealFactors.Clear();
        DailyNotes = null;
        await RefreshReferenceDataAsync();

        StatusMessage = "✅ Fattori pre-salvati. Domani puoi fare il commit del sonno.";
    }

    private async Task CommitSleep()
    {
        StatusMessage = null;

        if (!DateOnly.TryParse(CommitDayIso, out var commitDay))
        {
            StatusMessage = "Seleziona un giorno in pre-salvataggio da confermare.";
            return;
        }

        try
        {
            await DailyLogService.CommitSleepAsync(new CommitSleepInput(
                commitDay,
                SelectedSleepQuality,
                CommitNotes));

            CommitDayIso = null;
            CommitNotes = null;
            await RefreshReferenceDataAsync();
            StatusMessage = "🎉 Commit completato: sonno associato alla giornata pre-salvata.";
        }
        catch (InvalidOperationException ex)
        {
            StatusMessage = ex.Message;
        }
    }
}
